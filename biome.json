{
  "$schema": "https://biomejs.dev/schemas/2.0.6/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "includes": ["**", "!docs/**", "!typings/**"]
  },
  "linter": {
    "includes": ["**", "!**/*.yml", "!**/*.yaml", "!**/*.scss"],
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "indentStyle": "space",
    "formatWithErrors": true,
    "includes": ["**", "!**/*.yml", "!**/*.yaml", "!**/*.scss"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  }
}
